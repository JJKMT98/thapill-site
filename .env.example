PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# Database (required) — get a free Postgres at https://neon.tech
DATABASE_URL=postgres://user:pass@host/dbname?sslmode=require

# Auth (required)
JWT_SECRET=replace-with-a-long-random-string

# Admin (optional — the email that can access /admin)
ADMIN_EMAIL=hello@thapill.com

# Stripe (optional — orders auto-complete in dev if these are missing)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# SMTP (optional — transactional emails log to console if missing)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=hello@thapill.com
SMTP_PASS=replace-with-smtp-password
SMTP_FROM="thaPill <hello@thapill.com>"
