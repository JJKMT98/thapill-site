{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/order/success/:path*", "destination": "/order-success.html" },
    { "source": "/tracking/:path*", "destination": "/tracking.html" },
    { "source": "/api/:path*", "destination": "/404.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
